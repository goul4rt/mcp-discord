# Discord Bot Token (required)
DISCORD_TOKEN=your-bot-token-here

# Whether to connect to the Discord gateway (WebSocket)
# Set to "true" for real-time features (presence, live mentions)
# Set to "false" for REST-only mode (lighter, sufficient for most operations)
DISCORD_USE_GATEWAY=false

# MCP Transport: "stdio" (default) or "http"
MCP_TRANSPORT=stdio

# HTTP port (only used when MCP_TRANSPORT=http)
MCP_PORT=3100

# Authentication token for HTTP transport (recommended when MCP_TRANSPORT=http)
# If set, all HTTP requests must include: Authorization: Bearer <token>
# If not set, a warning is logged but the server runs without authentication
MCP_AUTH_TOKEN=your-secure-random-token-here
